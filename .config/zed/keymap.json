[
  // Alias space → cmd-space in vim normal mode so the universal leader bindings work
  // (also prevents vim::WrappingRight from conflicting with which-key)
  {
    "context": "(VimControl && !menu) || EmptyPane || (GitPanel && ChangesList && !GitBranchSelector)",
    "bindings": {
      "space": ["workspace::SendKeystrokes", "cmd-space"],
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      // Save
      "ctrl-s": "workspace::Save",

      // File hopping
      "cmd-space space": "file_finder::Toggle",
      "cmd-space ,": "tab_switcher::ToggleAll",

      // Search
      "cmd-space s g": "pane::DeploySearch",

      // Code actions (editor-specific, but harmless from other contexts)
      "cmd-space c r": "editor::Rename",
      "cmd-space c a": "editor::ToggleCodeActions",
      "cmd-space c f": "editor::Format",
      "cmd-space c o": "outline::Toggle",

      // File Explorer
      "cmd-space e": "project_panel::ToggleFocus",

      // Terminal
      "cmd-space t t": "terminal_panel::ToggleFocus",
      "cmd-space t f": "workspace::NewCenterTerminal",
      "cmd-space t n": "workspace::NewTerminal",
      "cmd-space t r": "terminal::RenameTerminal",

      // Git
      "cmd-space g s": "git_panel::ToggleFocus",
      "cmd-space g p": "git::Pull",
      "cmd-space g P": "git::Push",
      "cmd-space g b": "git::Branch",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl-space": "editor::ShowCompletions",
    },
  },
  // --- Git Panel ---
  {
    "context": "GitPanel && ChangesList && !GitBranchSelector",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "git_panel::FocusEditor",
    },
  },
  // --- Tab Switcher ---
  {
    "context": "TabSwitcher",
    "bindings": {
      "ctrl-x": "tab_switcher::CloseSelectedItem",
    },
  },
  // --- Editor (vim normal mode) ---
  {
    "context": "vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-{": "pane::SwapItemLeft",
      "ctrl-}": "pane::SwapItemRight",
    },
  },
  {
    "context": "GitPanel > Editor && vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      "escape": "workspace::CloseActiveDock",
      "ctrl-k": "git_panel::FocusChanges",
    },
  },
  // --- Terminal ---
  {
    "context": "Terminal",
    "unbind": {
      "cmd-k": "terminal::Clear",
    },
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-{": "pane::SwapItemLeft",
      "ctrl-}": "pane::SwapItemRight",
    },
  },
  // --- Project panel ---
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "a": "project_panel::NewFile",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "escape": "workspace::CloseActiveDock",
    },
  },
  {
    "context": "vim_mode == normal || vim_mode == visual || vim_mode == operator",
    "unbind": {
      "[ e": "editor::MoveLineUp",
      "] e": "editor::MoveLineDown",
    },
    "bindings": {
      "] e": "editor::GoToDiagnostic",
    },
  },
  {
    "context": "vim_mode == normal || vim_mode == visual || vim_mode == operator",
    "unbind": {},
  },
]
